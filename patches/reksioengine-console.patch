 abstract class SimpleFileLoader extends FileLoader {
+    protected resolveListedPath(filename: string): string | null {
+        const normalizedFilename = normalizePath(filename)
+        const listing = this.getFilesListing()
+
+        if (listing.includes(normalizedFilename)) {
+            return normalizedFilename
+        }
+
+        const suffix = `/${normalizedFilename}`
+        const matches = listing.filter((entry) => entry.endsWith(suffix))
+
+        if (matches.length === 1) {
+            logger.warn(`Resolved '${normalizedFilename}' from nested path '${matches[0]}'`)
+            return matches[0]
+        }
+
+        if (matches.length > 1) {
+            logger.warn(`Found multiple nested candidates for '${normalizedFilename}'`, {
+                candidates: matches.slice(0, 10),
+            })
+        }
+
+        return null
+    }
